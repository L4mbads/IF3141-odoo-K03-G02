<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="satuan_gram" model="janari.satuan">
            <field name="name">Gram</field><field name="category">berat</field><field name="factor">1</field>
        </record>
        <record id="satuan_kg" model="janari.satuan">
            <field name="name">Kilogram</field><field name="category">berat</field><field name="factor">1000</field>
        </record>
        <record id="satuan_ml" model="janari.satuan">
            <field name="name">Mililiter</field><field name="category">volume</field><field name="factor">1</field>
        </record>
        <record id="satuan_liter" model="janari.satuan">
            <field name="name">Liter</field><field name="category">volume</field><field name="factor">1000</field>
        </record>
        <record id="satuan_buah" model="janari.satuan">
            <field name="name">Buah</field><field name="category">jumlah</field><field name="factor">1</field>
        </record>
        <record id="satuan_sdm" model="janari.satuan">
            <field name="name">Sendok Makan</field><field name="category">volume</field><field name="factor">15</field>
        </record>
        <record id="satuan_sdt" model="janari.satuan">
            <field name="name">Sendok Teh</field><field name="category">volume</field><field name="factor">5</field>
        </record>
        <record id="satuan_porsi" model="janari.satuan">
            <field name="name">Porsi</field><field name="category">jumlah</field><field name="factor">1</field>
        </record>
        <record id="satuan_sachet" model="janari.satuan">
            <field name="name">Sachet</field><field name="category">jumlah</field><field name="factor">1</field>
        </record>

        <!-- ===================== BAHAN BAKU (3) ===================== -->

        <record id="bahan_baku_kopi_arabica" model="janari.bahan.baku">
            <field name="name">Biji Kopi Arabica</field>
            <field name="jenis">Bahan Utama</field>
            <field name="satuan" ref="satuan_gram"/>
            <field name="harga">250</field>
            <field name="vendor">Roastery Lokal Bandung</field>
            <field name="stok_saat_ini">5000</field>
            <field name="reorder_point">1000</field>
        </record>

        <record id="bahan_baku_susu_uht" model="janari.bahan.baku">
            <field name="name">Susu UHT Full Cream</field>
            <field name="jenis">Bahan Pendukung</field>
            <field name="satuan" ref="satuan_ml"/>
            <field name="harga">15</field>
            <field name="vendor">Distributor Susu</field>
            <field name="stok_saat_ini">10000</field>
            <field name="reorder_point">2000</field>
        </record>

        <record id="bahan_baku_gula_aren" model="janari.bahan.baku">
            <field name="name">Sirup Gula Aren</field>
            <field name="jenis">Bahan Pendukung</field>
            <field name="satuan" ref="satuan_ml"/>
            <field name="harga">20</field>
            <field name="stok_saat_ini">2000</field>
            <field name="reorder_point">500</field>
        </record>

        <!-- ===================== MENU (3) ===================== -->
        <record id="menu_kopi_susu_janari" model="janari.menu">
            <field name="name">Es Kopi Susu Janari</field>
            <field name="harga_menu">25000</field>
            <field name="status_menu">tersedia</field>
        </record>

        <record id="menu_americano" model="janari.menu">
            <field name="name">Iced Americano</field>
            <field name="harga_menu">20000</field>
            <field name="status_menu">tersedia</field>
        </record>

        <record id="menu_matcha_latte" model="janari.menu">
            <field name="name">Matcha Latte</field>
            <field name="harga_menu">28000</field>
            <field name="status_menu">tersedia</field>
        </record>

        <!-- ===================== RESEP / BOM ===================== -->
        <record id="resep_kopsus_kopi" model="janari.resep">
            <field name="menu_id" ref="menu_kopi_susu_janari"/>
            <field name="bahan_baku_id" ref="bahan_baku_kopi_arabica"/>
            <field name="jumlah_bahan">18</field>
            <field name="satuan" ref="satuan_gram"/>
        </record>

        <record id="resep_kopsus_susu" model="janari.resep">
            <field name="menu_id" ref="menu_kopi_susu_janari"/>
            <field name="bahan_baku_id" ref="bahan_baku_susu_uht"/>
            <field name="jumlah_bahan">150</field>
            <field name="satuan" ref="satuan_ml"/>
        </record>

        <record id="resep_kopsus_gula" model="janari.resep">
            <field name="menu_id" ref="menu_kopi_susu_janari"/>
            <field name="bahan_baku_id" ref="bahan_baku_gula_aren"/>
            <field name="jumlah_bahan">20</field>
            <field name="satuan" ref="satuan_gram"/>
        </record>

        <record id="resep_americano_kopi" model="janari.resep">
            <field name="menu_id" ref="menu_americano"/>
            <field name="bahan_baku_id" ref="bahan_baku_kopi_arabica"/>
            <field name="jumlah_bahan">20</field>
            <field name="satuan" ref="satuan_gram"/>
        </record>

        <record id="resep_matcha_susu" model="janari.resep">
            <field name="menu_id" ref="menu_matcha_latte"/>
            <field name="bahan_baku_id" ref="bahan_baku_susu_uht"/>
            <field name="jumlah_bahan">200</field>
            <field name="satuan" ref="satuan_ml"/>
        </record>

        <record id="resep_matcha_gula" model="janari.resep">
            <field name="menu_id" ref="menu_matcha_latte"/>
            <field name="bahan_baku_id" ref="bahan_baku_gula_aren"/>
            <field name="jumlah_bahan">15</field>
            <field name="satuan" ref="satuan_gram"/>
        </record>

        <!-- ===================== PESANAN (3) ===================== -->

        <!-- Pesanan 1 — status ordered (tampil merah di KDS) -->
        <record id="pesanan_dummy_01" model="janari.pesanan">
            <field name="name">ORD-TEST-001</field>
            <field name="nomor_meja">A1</field>
            <field name="sumber_pesanan">offline</field>
            <field name="status_pesanan">confirmed</field>
        </record>

        <record id="detail_pesanan_dummy_01_a" model="janari.detail.pesanan">
            <field name="pesanan_id" ref="pesanan_dummy_01"/>
            <field name="menu_id" ref="menu_kopi_susu_janari"/>
            <field name="jumlah">2</field>
            <field name="catatan">tidak terlalu manis</field>
            <field name="status_item">ordered</field>
        </record>

        <record id="detail_pesanan_dummy_01_b" model="janari.detail.pesanan">
            <field name="pesanan_id" ref="pesanan_dummy_01"/>
            <field name="menu_id" ref="menu_americano"/>
            <field name="jumlah">1</field>
            <field name="status_item">ordered</field>
        </record>

        <!-- Pesanan 2 — status processed (tampil kuning di KDS) -->
        <record id="pesanan_dummy_02" model="janari.pesanan">
            <field name="name">ORD-TEST-002</field>
            <field name="nomor_meja">B3</field>
            <field name="sumber_pesanan">online</field>
            <field name="status_pesanan">confirmed</field>
        </record>

        <record id="detail_pesanan_dummy_02_a" model="janari.detail.pesanan">
            <field name="pesanan_id" ref="pesanan_dummy_02"/>
            <field name="menu_id" ref="menu_americano"/>
            <field name="jumlah">1</field>
            <field name="catatan">es batu dipisah</field>
            <field name="status_item">processed</field>
        </record>

        <!-- Pesanan 3 — mix ordered dan processed (tampil di KDS) -->
        <record id="pesanan_dummy_03" model="janari.pesanan">
            <field name="name">ORD-TEST-003</field>
            <field name="nomor_meja">C2</field>
            <field name="sumber_pesanan">offline</field>
            <field name="status_pesanan">confirmed</field>
        </record>

        <record id="detail_pesanan_dummy_03_a" model="janari.detail.pesanan">
            <field name="pesanan_id" ref="pesanan_dummy_03"/>
            <field name="menu_id" ref="menu_matcha_latte"/>
            <field name="jumlah">2</field>
            <field name="catatan">gula dipisah</field>
            <field name="status_item">ordered</field>
        </record>

        <record id="detail_pesanan_dummy_03_b" model="janari.detail.pesanan">
            <field name="pesanan_id" ref="pesanan_dummy_03"/>
            <field name="menu_id" ref="menu_kopi_susu_janari"/>
            <field name="jumlah">1</field>
            <field name="status_item">processed</field>
        </record>

        <!-- ===================== LOG RIWAYAT STATUS ===================== -->

        <!-- ORD-002 item 1: ordered → processed -->
        <record id="log_dummy_02_a_processed" model="janari.update.status">
            <field name="detail_pesanan_id" ref="detail_pesanan_dummy_02_a"/>
            <field name="status_before">ordered</field>
            <field name="status_after">processed</field>
            <field name="updated_by" ref="base.user_admin"/>
            <field name="updated_at">2026-05-14 09:15:00</field>
            <field name="note">Mulai diproses</field>
        </record>

        <!-- ORD-003 item B: ordered → processed -->
        <record id="log_dummy_03_b_processed" model="janari.update.status">
            <field name="detail_pesanan_id" ref="detail_pesanan_dummy_03_b"/>
            <field name="status_before">ordered</field>
            <field name="status_after">processed</field>
            <field name="updated_by" ref="base.user_admin"/>
            <field name="updated_at">2026-05-14 09:30:00</field>
        </record>

        <!-- User Dummy -->
        <record id="user_kasir_dummy" model="res.users">
            <field name="name">Andi Kasir</field>
            <field name="login">kasir</field>
            <field name="password">kasir123</field>
            <field name="groups_id" eval="[(6, 0, [ref('base.group_user'), ref('janari_sistem.group_janari_kasir')])]"/>
        </record>

        <record id="user_dapur_dummy" model="res.users">
            <field name="name">Doni Dapur</field>
            <field name="login">dapur</field>
            <field name="password">dapur123</field>
            <field name="groups_id" eval="[(6, 0, [ref('base.group_user'), ref('janari_sistem.group_janari_dapur')])]"/>
        </record>

        <record id="user_pemilik_dummy" model="res.users">
            <field name="name">Bapak Pemilik</field>
            <field name="login">pemilik</field>
            <field name="password">pemilik123</field>
            <field name="groups_id" eval="[(6, 0, [ref('base.group_user'), ref('janari_sistem.group_janari_pemilik')])]"/>
        </record>
    </data>
</odoo>
