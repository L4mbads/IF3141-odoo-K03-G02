            <field name="jumlah_bahan">20</field> </record>

        <record id="resep_americano_kopi" model="janari.resep">
            <field name="menu_id" ref="menu_americano"/>
            <field name="bahan_baku_id" ref="bahan_baku_kopi_arabica"/>
