<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================== SEARCH VIEW ===================== -->
    <record id="view_janari_alert_search" model="ir.ui.view">
        <field name="name">janari.bahan.baku.alert.search</field>
        <field name="model">janari.bahan.baku</field>
        <field name="arch" type="xml">
            <search string="Cari Peringatan Stok">
                <field name="name" string="Nama Bahan"/>
                <separator/>
                <filter name="filter_belum_ditangani" string="Belum Ditangani"
                        domain="[('is_alert_handled', '=', False), ('is_low_stock', '=', True)]"/>
                <filter name="filter_sudah_ditangani" string="Sudah Ditangani"
                        domain="[('is_alert_handled', '=', True)]"/>
            </search>
        </field>
    </record>

    <!-- ===================== LIST VIEW ===================== -->
    <record id="view_janari_alert_tree" model="ir.ui.view">
        <field name="name">janari.bahan.baku.alert.tree</field>
        <field name="model">janari.bahan.baku</field>
        <field name="arch" type="xml">
            <tree string="Peringatan Stok"
                  decoration-danger="is_low_stock == True and is_alert_handled == False"
                  decoration-muted="is_alert_handled == True"
                  create="false">
                <field name="name"/>
                <field name="vendor"/>
                <field name="stok_saat_ini"/>
                <field name="satuan"/>
                <field name="reorder_point"/>
                <field name="is_alert_handled" string="Status Penanganan"
                       widget="toggle_button"
                       options="{'terminology': {'string_true': 'Sudah Ditangani', 'string_false': 'Belum Ditangani', 'hover_true': 'Buka Kembali', 'hover_false': 'Tandai Ditangani'}}"/>
                <field name="is_low_stock" invisible="1"/>
                <button name="action_tandai_ditangani" string="Tandai Ditangani"
                        type="object" icon="fa-check"
                        class="btn-success btn-sm"
                        invisible="is_alert_handled == True"/>
                <button name="action_buka_kembali" string="Buka Kembali"
                        type="object" icon="fa-undo"
                        class="btn-secondary btn-sm"
                        invisible="is_alert_handled == False"/>
            </tree>
        </field>
    </record>

    <!-- ===================== ACTION ===================== -->
    <record id="action_janari_alert_stok" model="ir.actions.act_window">
        <field name="name">Peringatan Stok Rendah</field>
        <field name="res_model">janari.bahan.baku</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_low_stock', '=', True)]</field>
        <field name="view_id" ref="view_janari_alert_tree"/>
        <field name="search_view_id" ref="view_janari_alert_search"/>
        <field name="context">{'search_default_filter_belum_ditangani': 1}</field>
    </record>

    <!-- ===================== MENU ===================== -->
    <menuitem id="menu_janari_alert"
              name="Peringatan Stok"
              parent="menu_janari_inventory"
              action="action_janari_alert_stok"
              sequence="40"
              groups="janari_sistem.group_janari_kepala_staf,janari_sistem.group_janari_pemilik"/>
</odoo>