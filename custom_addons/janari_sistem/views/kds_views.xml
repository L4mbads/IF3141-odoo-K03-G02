<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_janari_kds_kanban" model="ir.ui.view">
        <field name="name">janari.detail.pesanan.kanban</field>
        <field name="model">janari.detail.pesanan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status_item" quick_create="false">
                <field name="menu_id"/>
                <field name="jumlah"/>
                <field name="status_item"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="menu_id"/>
                                </strong>
                                <div>
                                    <span>Jumlah: <field name="jumlah"/></span>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="status_item" widget="label_selection" options="{'classes': {'ordered': 'default', 'processed': 'warning', 'done': 'success'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_janari_kds" model="ir.actions.act_window">
        <field name="name">Kitchen Display System</field>
        <field name="res_model">janari.detail.pesanan</field>
        <field name="view_mode">kanban</field>
        <field name="domain">[('status_item', '!=', 'done')]</field> </record>

    <menuitem id="menu_janari_kds_screen" name="Layar Dapur" parent="menu_janari_kds" action="action_janari_kds" sequence="10"/>
</odoo>