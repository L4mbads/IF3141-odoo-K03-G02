<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_janari_pesanan_tree" model="ir.ui.view">
        <field name="name">janari.pesanan.tree</field>
        <field name="model">janari.pesanan</field>
        <field name="arch" type="xml">
            <tree string="Pesanan">
                <field name="name"/>
                <field name="tanggal_pesanan"/>
                <field name="total_harga"/>
                <field name="status_pesanan" widget="badge" decoration-info="status_pesanan == 'draft'" decoration-success="status_pesanan == 'done'"/>
            </tree>
        </field>
    </record>

    <record id="view_janari_pesanan_form" model="ir.ui.view">
        <field name="name">janari.pesanan.form</field>
        <field name="model">janari.pesanan</field>
        <field name="arch" type="xml">
            <form string="Input Pesanan">
                <header>
                    <button name="action_confirm" string="Konfirmasi Pembayaran" type="object" class="btn-primary" invisible="status_pesanan != 'draft'"/>
                    <field name="status_pesanan" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tanggal_pesanan"/>
                            <field name="nomor_meja"/>
                        </group>
                        <group>
                            <field name="sumber_pesanan"/>
                            <field name="total_harga" readonly="1"/>
                        </group>
                    </group>
                    <field name="detail_pesanan_ids">
                        <tree editable="bottom">
                            <field name="menu_id"/>
                            <field name="jumlah"/>
                            <field name="catatan"/>
                            <field name="subtotal" readonly="1"/>
                            <field name="status_item" readonly="1"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_janari_pesanan" model="ir.actions.act_window">
        <field name="name">Input Transaksi POS</field>
        <field name="res_model">janari.pesanan</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_janari_pos_order" name="Pesanan Baru" parent="menu_janari_pos" action="action_janari_pesanan" sequence="10" groups="janari_sistem.group_janari_kasir"/>
</odoo>